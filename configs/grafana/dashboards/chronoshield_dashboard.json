{
  "id": null,
  "uid": "chronoshield-ops",
  "title": "ChronoShield AI — Operational Metrics",
  "description": "Enterprise observability dashboard for ChronoShield AI: API throughput, anomaly engine, cache performance, and centralized logs.",
  "tags": ["chronoshield", "ai", "observability"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🌐 API Performance",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "API Request Rate (req/s)",
      "description": "HTTP request throughput per second grouped by endpoint",
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "sum(rate(http_requests_total{job=\"chronoshield-backend\"}[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "API Error Rate (%)",
      "description": "Percentage of HTTP 4xx / 5xx responses",
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "100 * sum(rate(http_requests_total{job=\"chronoshield-backend\", status=~\"4..|5..\"}[1m])) / sum(rate(http_requests_total{job=\"chronoshield-backend\"}[1m]))",
          "legendFormat": "Backend Error Rate %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "API Response Latency (p50 / p95 / p99)",
      "description": "Request duration percentiles for the backend service",
      "gridPos": { "x": 0, "y": 9, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"chronoshield-backend\"}[2m])) by (le, endpoint))",
          "legendFormat": "p50 {{endpoint}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"chronoshield-backend\"}[2m])) by (le, endpoint))",
          "legendFormat": "p95 {{endpoint}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"chronoshield-backend\"}[2m])) by (le, endpoint))",
          "legendFormat": "p99 {{endpoint}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Requests (1h)",
      "gridPos": { "x": 16, "y": 9, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "unit": "short",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "sum(increase(http_requests_total{job=\"chronoshield-backend\"}[1h]))",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "🧠 AI Anomaly Engine",
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Anomalies Detected (rate/min)",
      "description": "Rate of anomalies flagged by the AI Engine per minute, grouped by severity",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "HIGH" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "MEDIUM" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "LOW" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "sum(rate(anomalies_detected_total{job=\"chronoshield-ai-engine\"}[1m])) by (severity) * 60",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Inference Latency (p50 / p95 / p99)",
      "description": "AI Engine anomaly inference duration percentiles",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(inference_duration_seconds_bucket{job=\"chronoshield-ai-engine\"}[2m])) by (le))",
          "legendFormat": "p50 Inference",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(inference_duration_seconds_bucket{job=\"chronoshield-ai-engine\"}[2m])) by (le))",
          "legendFormat": "p95 Inference",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(inference_duration_seconds_bucket{job=\"chronoshield-ai-engine\"}[2m])) by (le))",
          "legendFormat": "p99 Inference",
          "refId": "C"
        }
      ]
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Total Anomalies Detected (1h)",
      "gridPos": { "x": 0, "y": 26, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "sum(increase(anomalies_detected_total{job=\"chronoshield-ai-engine\"}[1h]))",
          "legendFormat": "Anomalies",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Model Training Duration",
      "description": "Time to train temporal autoencoder models (per training call)",
      "gridPos": { "x": 6, "y": 26, "w": 10, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(model_training_duration_seconds_bucket{job=\"chronoshield-ai-engine\"}[5m])) by (le))",
          "legendFormat": "p95 Training Time",
          "refId": "A"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Ingestion Pipeline Throughput",
      "description": "Records ingested per second by data source type",
      "gridPos": { "x": 16, "y": 26, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 12 },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "sum(rate(ingestion_records_processed_total{job=\"chronoshield-ai-engine\"}[1m])) by (source_type)",
          "legendFormat": "{{source_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "🔔 Alert Intelligence",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "bargauge",
      "title": "Active Alerts by Severity",
      "description": "Current count of active DB alerts, grouped by severity classification",
      "gridPos": { "x": 0, "y": 33, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short",
          "min": 0
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red" } }] },
          { "matcher": { "id": "byName", "options": "HIGH" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "MEDIUM" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "LOW" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }
        ]
      },
      "options": {
        "orientation": "vertical",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "active_alerts_count{job=\"chronoshield-backend\"}",
          "legendFormat": "{{severity}} / {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Alert Count Over Time",
      "description": "Historical trend of active alert counts by severity",
      "gridPos": { "x": 12, "y": 33, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "sum(active_alerts_count{job=\"chronoshield-backend\"}) by (severity)",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "⚡ Cache Performance",
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "gauge",
      "title": "Cache Hit Rate (%)",
      "description": "Percentage of cache read operations that are hits vs misses",
      "gridPos": { "x": 0, "y": 42, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "100 * sum(rate(cache_operations_total{job=\"chronoshield-backend\", status=\"hit\"}[5m])) / (sum(rate(cache_operations_total{job=\"chronoshield-backend\", operation=\"read\"}[5m])) + 0.001)",
          "legendFormat": "Hit Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Cache Operations Rate",
      "description": "Rate of cache hits, misses, and writes per second",
      "gridPos": { "x": 8, "y": 42, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "hit" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "miss" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "failure" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "sum"] },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "chronoshield-prometheus" },
          "expr": "sum(rate(cache_operations_total{job=\"chronoshield-backend\"}[1m])) by (operation, status)",
          "legendFormat": "{{operation}} / {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "📋 Centralized Logs",
      "gridPos": { "x": 0, "y": 50, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 41,
      "type": "logs",
      "title": "Backend Service Logs",
      "description": "Live structured logs from the ChronoShield backend service",
      "gridPos": { "x": 0, "y": 51, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "chronoshield-loki" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "chronoshield-loki" },
          "expr": "{job=\"chronoshield-backend\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 42,
      "type": "logs",
      "title": "AI Engine Logs",
      "description": "Live structured logs from the ChronoShield AI Engine service",
      "gridPos": { "x": 0, "y": 61, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "chronoshield-loki" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "chronoshield-loki" },
          "expr": "{job=\"chronoshield-ai-engine\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
