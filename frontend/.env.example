# ==============================================================================
# ChronoShield AI — Frontend Environment Variables (Vite)
# ==============================================================================
# Copy this file to frontend/.env.local and configure per environment.
# All variables MUST start with VITE_ to be exposed to the browser bundle.

# Base URL for the FastAPI backend API.
# Override in Docker with the container service hostname (e.g. http://backend:8000)
VITE_API_URL=http://localhost:8000

# Application display metadata
VITE_APP_TITLE="ChronoShield AI Platform"

# WebSocket endpoint for future real-time feeds
VITE_WS_URL=ws://localhost:8000/ws
