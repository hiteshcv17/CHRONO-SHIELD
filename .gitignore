# ChronoShield AI Monorepo Gitignore

# ==============================================================================
# System / OS
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==============================================================================
# Python / FastAPI / AI Engine
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Pyinstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or app, you might want to share your .python-version.
#   Comment out the following line if you want to share it.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing a Python library project, you may decide to ignore it.
# Pipfile.lock

# poetry
#   Poetry uses pyproject.toml and poetry.lock. Locking is recommended for apps, optional for libs.
# poetry.lock

# pdm
#   PDM stores local configuration in .pdm-python and uses pdm.lock for locking.
.pdm-python
pdm.lock

# virtualenv
venv/
.venv/
ENV/
env/
active_env/
conda-env/

# spyder
.spyderproject
.spyder-py3

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static analyzer
.pytype/

# Cython debug symbols
cython_debug/

# ==============================================================================
# Frontend / React / Node.js
# ==============================================================================
node_modules/
/frontend/dist
/frontend/dist-ssr
/frontend/.svelte-kit
/frontend/.next
/frontend/out
/frontend/build

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-gyp compilation files (https://github.com/nodejs/node-gyp)
build/Release

# Yeoman generator caches
.yo-rc.json

# Dependency directories
jspm_packages/

# TypeScript v1.x command line compiler cache
tsconfig.tsbuildinfo

# trey research; intellectual property
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# npm/pnpm/yarn packages
pnpm-lock.yaml
yarn.lock

# debug logs
logs/
*.log

# ==============================================================================
# Docker & Infrastructure
# ==============================================================================
.docker/
docker-compose.override.yml

# ==============================================================================
# IDEs / Editors
# ==============================================================================
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
