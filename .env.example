# ==============================================================================
# ChronoShield AI Master Environment Template
# ==============================================================================
# Copy this file to .env and configure local values. 
# Do NOT commit raw secret credentials to source control.

# ------------------------------------------------------------------------------
# Global Platform Environment Settings
# ------------------------------------------------------------------------------
ENVIRONMENT=development  # development, staging, production
PROJECT_NAME="ChronoShield AI"
VERSION="1.0.0"

# ------------------------------------------------------------------------------
# FastAPI Backend Settings
# ------------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info
SECRET_KEY=replace_with_a_highly_secure_cryptographic_random_string_32_bytes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Outbound SMTP Alert Settings (Enterprise Production Real-Time Alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_username@gmail.com
SMTP_PASSWORD=your_secure_smtp_app_password
SMTP_RECIPIENT_EMAIL=ops-alerts@chronoshield.ai
SMTP_ALLOWED_SEVERITIES=CRITICAL,HIGH

# ------------------------------------------------------------------------------
# PostgreSQL Database Settings
# ------------------------------------------------------------------------------
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_postgres_pass_998
POSTGRES_DB=chronoshield_db
# SQLAlchemy async connection string
DATABASE_URL=postgresql+asyncpg://postgres:secure_postgres_pass_998@localhost:5432/chronoshield_db

# ------------------------------------------------------------------------------
# Redis Settings (for Pub/Sub and Cache Layer)
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=secure_redis_pass_112
REDIS_DB=0
REDIS_URL=redis://:secure_redis_pass_112@localhost:6379/0

# ------------------------------------------------------------------------------
# AI Engine Settings
# ------------------------------------------------------------------------------
AI_ENGINE_HOST=0.0.0.0
AI_ENGINE_PORT=8001
AI_MODEL_DIR=./ai-engine/models/registry
AI_LOG_LEVEL=info
AI_TRAIN_BATCH_SIZE=64
AI_DEFAULT_EPOCHS=10
AI_ANOMALY_THRESHOLD=0.85

# ------------------------------------------------------------------------------
# React Frontend Settings
# ------------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
VITE_APP_TITLE="ChronoShield AI Platform"

# ------------------------------------------------------------------------------
# Logging & Metrics
# ------------------------------------------------------------------------------
LOGS_DIR=./logs
PROMETHEUS_METRICS_PORT=9090
GRAFANA_PORT=3000
